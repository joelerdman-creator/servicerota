rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperUser() {
      // superUser status is determined SOLELY by the custom claim.
      return request.auth.token.superUser == true;
    }
    
    function isRequestingUser(userId) {
        return isSignedIn() && request.auth.uid == userId;
    }

    // Checks if the requesting user is an admin of the specified church.
    function isChurchAdmin(churchId) {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             userDoc.data.isAdmin == true &&
             userDoc.data.churchId == churchId;
    }

    // Checks if the requesting user is an active member (volunteer or admin) of the specified church.
    function isChurchMember(churchId) {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             userDoc.data.churchId == churchId &&
             userDoc.data.status == "active";
    }
    
    // --- USER PROFILES ---
    match /users/{userId} {
      allow get: if isSuperUser() || isRequestingUser(userId) || isChurchAdmin(resource.data.churchId);
      // IMPORTANT: This list rule allows queries on the users collection. 
      // The queries themselves MUST be secured with where() clauses in the client code.
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSuperUser() || isRequestingUser(userId) || isChurchAdmin(resource.data.churchId);
      allow delete: if isSuperUser() || isChurchAdmin(resource.data.churchId);
    }

    // --- CHURCH DATA & SUBCOLLECTIONS ---
    match /churches/{churchId} {
      // Public get for widget/embed pages; subscription fields (planId, etc.) are non-sensitive
      allow get: if true;
      allow list: if isSuperUser();
      allow create: if isSuperUser() || (isSignedIn() && request.resource.data.ownerId == request.auth.uid);
      // Only admins can update — protects planId, stripeCustomerId, etc. from client tampering
      allow update: if isSuperUser() || isChurchAdmin(churchId);

      // --- EVENTS ---
      match /events/{eventId} {
        // Admins can read all events. Active members can list events (needed to
        // discover recurring series for preferences). Individual unpublished event
        // gets are restricted to admins.
        allow list: if isSuperUser() || isChurchAdmin(churchId) || isChurchMember(churchId);
        allow get: if resource.data.isPublished == true || isSuperUser() || isChurchAdmin(churchId);
        allow write: if isSuperUser() || isChurchAdmin(churchId);

        // --- ROLES ---
        match /roles/{roleId} {
            function isSigningUpForOpenRole() {
                let event = get(/databases/$(database)/documents/churches/$(churchId)/events/$(eventId));
                // Allow update if the event is a sign-up event, the role is currently unassigned,
                // and the user is assigning themselves.
                return event.data.isSignupEnabled == true &&
                       resource.data.assignedVolunteerId == null &&
                       request.resource.data.assignedVolunteerId == request.auth.uid &&
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['assignedVolunteerId', 'assignedVolunteerName', 'status']);
            }

            function isClaimingSubstitution() {
                return resource.data.status == "Pending Substitution" &&
                       request.resource.data.assignedVolunteerId == request.auth.uid &&
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['assignedVolunteerId', 'assignedVolunteerName', 'status']);
            }

            allow read, list: if get(/databases/$(database)/documents/churches/$(churchId)/events/$(eventId)).data.isPublished == true || isChurchAdmin(churchId);
            allow create, delete: if isChurchAdmin(churchId);
            allow update: if isChurchAdmin(churchId) || isSigningUpForOpenRole() || isClaimingSubstitution() ||
                          (isRequestingUser(resource.data.assignedVolunteerId) && 
                           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']));
        }
      }

      // --- TEMPLATES ---
      // Volunteers need to read role_templates to see what roles they can request.
      match /role_templates/{roleTemplateId} {
        allow read: if isSuperUser() || isChurchMember(churchId);
        allow write: if isSuperUser() || isChurchAdmin(churchId);
      }

      match /service_templates/{serviceTemplateId} {
        allow read, write: if isSuperUser() || isChurchAdmin(churchId);
      }
      
      match /series_metadata/{seriesId} {
        allow read, write: if isSuperUser() || isChurchAdmin(churchId);
      }

      // --- ROLE REQUESTS ---
      match /role_requests/{requestId} {
        // Admins can read and manage all requests for their church.
        allow read, list: if isSuperUser() || isChurchAdmin(churchId);
        allow update, delete: if isSuperUser() || isChurchAdmin(churchId);

        // Volunteers can create a request for themselves.
        allow create: if isChurchMember(churchId) &&
                         request.resource.data.volunteerId == request.auth.uid &&
                         request.resource.data.status == "pending";

        // Volunteers can read and cancel (delete) their own requests.
        allow get: if isChurchMember(churchId) && resource.data.volunteerId == request.auth.uid;
        allow list: if isChurchMember(churchId) && request.auth != null;
        allow delete: if isChurchMember(churchId) && resource.data.volunteerId == request.auth.uid
                         && resource.data.status == "pending";
      }

      // --- USAGE COUNTERS (SMS caps etc.) ---
      // Written server-side only; admins can read for dashboard display
      match /usage/{monthKey} {
        allow read: if isChurchAdmin(churchId);
        allow write: if false;
      }

      // --- NOTIFICATIONS ---
      match /notifications/{notificationId} {
        allow read, list: if isChurchAdmin(churchId);
        // Writes are handled by server-side actions, so no client-side write access is needed.
        allow write: if false; 
      }
    }
    
    // --- GRAPHIC ASSETS ---
    // Global stock images used in church flyer/sharing pages.
    // Writes are server-side only (Admin SDK); client reads limited to signed-in admins.
    match /graphic_assets/{assetId} {
      allow get, list: if isSuperUser() ||
        (isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true);
      allow write: if isSuperUser();
    }

    // --- SUPPORT TICKETS ---
    match /support_tickets/{ticketId} {
      allow create: if isSignedIn() && request.resource.data.submittedByUid == request.auth.uid;
      allow get: if isSuperUser() || (isSignedIn() && resource.data.submittedByUid == request.auth.uid);
      allow list: if isSuperUser() || (isSignedIn() && resource.data.submittedByUid == request.auth.uid) || isChurchAdmin(resource.data.churchId);
      allow update: if isSuperUser() || 
                    (isSignedIn() && resource.data.submittedByUid == request.auth.uid && 
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'lastActivityAt']));
      allow delete: if isSuperUser();
      
      match /comments/{commentId} {
        allow read, list: if isSuperUser() || (isSignedIn() && get(/databases/$(database)/documents/support_tickets/$(ticketId)).data.submittedByUid == request.auth.uid);
        allow create: if isSuperUser() || (isSignedIn() && get(/databases/$(database)/documents/support_tickets/$(ticketId)).data.submittedByUid == request.auth.uid);
      }
    }
  }
}
