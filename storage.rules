rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // User avatars: only the owner can write; authenticated users can read
    match /avatars/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.size < 2 * 1024 * 1024
                   && request.resource.contentType.matches('image/(jpeg|png)');
    }

    // Church logos: any authenticated admin of that church can write
    match /logos/{churchId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 2 * 1024 * 1024
                   && request.resource.contentType.matches('image/(jpeg|png)');
    }
  }
}
